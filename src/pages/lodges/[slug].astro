---
import BaseLayout from "../../layouts/BaseLayout.astro";
import NavSummitX from "../../components/NavSummitX.astro";
import Footer from "../../components/Footer.astro";
import PortableText from "../../components/PortableText.astro";
import EnquiryCTA from "../../components/EnquiryCTA.astro";
import LightboxGallery from "../../components/LightboxGallery.astro";
import PropertyMap from "../../components/PropertyMap.astro";
import { sanityClient } from "../../lib/sanity";

export async function getStaticPaths() {
  const items = await sanityClient.fetch(`*[_type == "lodge"]{ "slug": slug.current }`);
  return items.map((item: { slug: string }) => ({ params: { slug: item.slug } }));
}

const { slug } = Astro.params;

const lodge = await sanityClient.fetch(`
  *[_type == "lodge" && slug.current == $slug][0] {
    name, bedrooms, sleeps, priceOnRequest, priceRange, style, amenities, includedServices, onRequest, description,
    "location": location{ lat, lng },
    "heroUrl": gallery[0].asset->url + "?w=1600&auto=format",
    "gallery": gallery[]{ "url": asset->url + "?w=1200&auto=format" },
    "destination": destination->{ name, "slug": slug.current }
  }
`, { slug });

if (!lodge) return Astro.redirect("/lodges");

const priceDisplay = lodge.priceOnRequest || !lodge.priceRange?.min
  ? "Price on request"
  : `${lodge.priceRange.currency ?? "GBP"} ${lodge.priceRange.min.toLocaleString()}–${lodge.priceRange.max?.toLocaleString() ?? ""}`;

const descParts = [
  lodge.destination?.name && `in ${lodge.destination.name}`,
  lodge.bedrooms && `${lodge.bedrooms} bedrooms`,
  lodge.sleeps && `sleeps ${lodge.sleeps}`,
].filter(Boolean).join(", ");
const description = `${lodge.name}${descParts ? ` — ${descParts}` : ""}. A boutique mountain lodge curated by Summit X.`;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "LodgingBusiness",
  name: lodge.name,
  description,
  url: `https://summitx.iconprivatecollection.com/lodges/${slug}`,
  ...(lodge.heroUrl && { image: lodge.heroUrl }),
  ...(lodge.destination && { location: { "@type": "Place", name: lodge.destination.name } }),
  ...(lodge.amenities?.length && {
    amenityFeature: lodge.amenities.map((a: string) => ({ "@type": "LocationFeatureSpecification", name: a, value: true })),
  }),
  brand: { "@type": "Brand", name: "Summit X" },
  parentOrganization: { "@type": "Organization", name: "Icon Private Collection" },
  email: "summitx@iconprivatecollection.com",
};
---

<BaseLayout
  title={`${lodge.name} — Summit X`}
  description={description}
  image={lodge.heroUrl ?? undefined}
  structuredData={structuredData}
>
  <NavSummitX />
  <main id="main">
    {lodge.heroUrl && (
      <div class="detail-hero">
        <img src={lodge.heroUrl} alt={lodge.name} loading="eager" />
        <div class="overlay" style="background: var(--grad-veil);"></div>
        {lodge.gallery?.length > 1 && (
          <button class="hero-photo-count" data-lb-open="0">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            {lodge.gallery.length} photos
          </button>
        )}
      </div>
    )}

    <div class="detail-header container">
      {lodge.destination && (
        <p class="label-eyebrow reveal">
          <a href={`/destinations/${lodge.destination.slug}`}>{lodge.destination.name}</a>
        </p>
      )}
      <h1 class="display reveal reveal-delay-1">{lodge.name}</h1>
    </div>

    <div class="container detail-body">
      <div class="detail-description">
        {lodge.description && <PortableText blocks={lodge.description} />}
      </div>
      <aside class="detail-aside">
        <div class="detail-specs">
          <p class="label-eyebrow" style="margin-bottom: 0.5rem;">At a glance</p>
          {lodge.style && (
            <div class="detail-spec-row">
              <span class="label-eyebrow">Style</span>
              <span>{lodge.style}</span>
            </div>
          )}
          {lodge.bedrooms && (
            <div class="detail-spec-row">
              <span class="label-eyebrow">Bedrooms</span>
              <span>{lodge.bedrooms}</span>
            </div>
          )}
          {lodge.sleeps && (
            <div class="detail-spec-row">
              <span class="label-eyebrow">Sleeps</span>
              <span>{lodge.sleeps}</span>
            </div>
          )}
          <div class="detail-spec-row">
            <span class="label-eyebrow">Price</span>
            <span>{priceDisplay}</span>
          </div>
        </div>
      </aside>
    </div>

    {lodge.amenities?.length > 0 && (
      <div class="container">
        <div class="detail-aside" style="grid-column: 9 / span 4;">
          <div class="detail-tag-section">
            <p class="detail-tag-section-label">Amenities</p>
            <ul class="tag-list">
              {lodge.amenities.map((a: string) => <li class="tag">{a}</li>)}
            </ul>
          </div>
        </div>
      </div>
    )}

    {lodge.includedServices?.length > 0 && (
      <div class="container">
        <div class="detail-aside" style="grid-column: 9 / span 4;">
          <div class="detail-tag-section">
            <p class="detail-tag-section-label">Included Services</p>
            <ul class="tag-list">
              {lodge.includedServices.map((s: string) => <li class="tag">{s}</li>)}
            </ul>
          </div>
        </div>
      </div>
    )}

    {lodge.onRequest?.length > 0 && (
      <div class="container">
        <div class="detail-aside" style="grid-column: 9 / span 4;">
          <div class="detail-tag-section">
            <p class="detail-tag-section-label">On Request</p>
            <ul class="tag-list">
              {lodge.onRequest.map((r: string) => <li class="tag">{r}</li>)}
            </ul>
          </div>
        </div>
      </div>
    )}

    {lodge.location?.lat && lodge.location?.lng && (
      <PropertyMap lat={lodge.location.lat} lng={lodge.location.lng} label={lodge.name} />
    )}

    <LightboxGallery images={lodge.gallery ?? []} />

    <EnquiryCTA propertyName={lodge.name} />
  </main>
  <Footer />
</BaseLayout>
