---
import BaseLayout from "../../layouts/BaseLayout.astro";
import NavSummitX from "../../components/NavSummitX.astro";
import Footer from "../../components/Footer.astro";
import PortableText from "../../components/PortableText.astro";
import EnquiryCTA from "../../components/EnquiryCTA.astro";
import LightboxGallery from "../../components/LightboxGallery.astro";
import PropertyMap from "../../components/PropertyMap.astro";
import { sanityClient } from "../../lib/sanity";

export async function getStaticPaths() {
  const items = await sanityClient.fetch(`*[_type == "lodge"]{ "slug": slug.current }`);
  return items.map((item: { slug: string }) => ({ params: { slug: item.slug } }));
}

const { slug } = Astro.params;

const lodge = await sanityClient.fetch(`
  *[_type == "lodge" && slug.current == $slug][0] {
    name, bedrooms, sleeps, priceOnRequest, priceRange, style,
    amenities, includedServices, onRequest, description,
    tagline, shortDescription, editorialIntro, seoTitle, metaDescription,
    accessAndLogistics, seasonWindow, terrain, vimeoUrl,
    physicalRequirements { level, descriptor },
    signatureExperiences[] { name, description, link },
    faqs[] { question, answer },
    altitude,
    "location": location{ lat, lng },
    "heroUrl": gallery[0].asset->url + "?w=1600&auto=format",
    "gallery": gallery[]{ "url": asset->url + "?w=1200&auto=format" },
    "destination": destination->{ name, "slug": slug.current }
  }
`, { slug });

if (!lodge) return Astro.redirect("/lodges");

const seoTitle = lodge.seoTitle ?? `${lodge.name} — Summit X`;
const priceDisplay = lodge.priceOnRequest || !lodge.priceRange?.min
  ? "Price on request"
  : `${lodge.priceRange.currency ?? "GBP"} ${lodge.priceRange.min.toLocaleString()}–${lodge.priceRange.max?.toLocaleString() ?? ""}`;

const descParts = [
  lodge.destination?.name && `in ${lodge.destination.name}`,
  lodge.bedrooms && `${lodge.bedrooms} bedrooms`,
  lodge.sleeps && `sleeps ${lodge.sleeps}`,
].filter(Boolean).join(", ");
const seoDescription = lodge.metaDescription
  ?? `${lodge.name}${descParts ? ` — ${descParts}` : ""}. A boutique mountain lodge curated by Summit X.`;

const levelColor: Record<string, string> = {
  None: "#7ab97a",
  Moderate: "var(--ember)",
  Demanding: "#d96060",
};

function formatCoords(lat: number, lng: number): string {
  const fmt = (n: number) => (Math.trunc(n * 100) / 100).toFixed(2);
  const latDir = lat >= 0 ? "N" : "S";
  const lngDir = lng >= 0 ? "E" : "W";
  return `${fmt(lat)}°${latDir} · ${fmt(lng)}°${lngDir}`;
}

function textToHtml(text: string): string {
  const escaped = text.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
  return escaped
    .split(/\n\n+/)
    .map(para => `<p>${para.trim().replace(/\n/g, "<br>")}</p>`)
    .join("");
}
const editorialHtml = lodge.editorialIntro ? textToHtml(lodge.editorialIntro) : null;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "LodgingBusiness",
  name: lodge.name,
  description: seoDescription,
  url: `https://summitx.iconprivatecollection.com/lodges/${slug}`,
  ...(lodge.heroUrl && { image: lodge.heroUrl }),
  ...(lodge.destination && { location: { "@type": "Place", name: lodge.destination.name } }),
  ...(lodge.amenities?.length && {
    amenityFeature: lodge.amenities.map((a: string) => ({
      "@type": "LocationFeatureSpecification",
      name: a,
      value: true,
    })),
  }),
  brand: { "@type": "Brand", name: "Summit X" },
  parentOrganization: { "@type": "Organization", name: "Icon Private Collection" },
  email: "summitx@iconprivatecollection.com",
};
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  image={lodge.heroUrl ?? undefined}
  structuredData={structuredData}
>
  <NavSummitX />
  <main id="main">

    {lodge.heroUrl && (
      <div class="detail-hero">
        <img src={lodge.heroUrl} alt={lodge.name} loading="eager" />
        <div class="overlay" style="background: var(--grad-veil);"></div>
        {lodge.vimeoUrl && (
          <div id="hero-video-overlay" class="hero-video-overlay" hidden>
            <iframe id="hero-video" class="hero-video-player" src="" allow="autoplay; fullscreen" allowfullscreen></iframe>
          </div>
        )}
        <div class="hero-media-btns">
          {lodge.vimeoUrl && (
            <button class="hero-watch-film" id="watch-film-btn">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              Watch film
            </button>
          )}
          {lodge.gallery?.length > 1 && (
            <button class="hero-photo-count" data-lb-open="0">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
              {lodge.gallery.length} photos
            </button>
          )}
        </div>
      </div>
    )}
    <script is:inline define:vars={{ vimeoUrl: lodge.vimeoUrl }}>
      if (vimeoUrl) {
        const btn = document.getElementById("watch-film-btn");
        const video = document.getElementById("hero-video");
        const videoId = vimeoUrl.match(/(?:vimeo\.com\/)(\d+)/)?.[1];
        const overlay = document.getElementById("hero-video-overlay");
        const embedUrl = "https://player.vimeo.com/video/" + videoId + "?autoplay=1&title=0&byline=0&portrait=0";
        function openVideo() { video.src = embedUrl; overlay.hidden = false; btn.hidden = true; }
        function closeVideo() { overlay.hidden = true; video.src = ""; btn.hidden = false; }
        btn?.addEventListener("click", openVideo);
        overlay?.addEventListener("click", function(e) { if (!e.target.closest(".hero-video-player")) closeVideo(); });
        document.addEventListener("keydown", function(e) { if (e.key === "Escape" && !overlay.hidden) closeVideo(); });
      }
    </script>

    <div class="detail-header container">
      <div class="detail-header-meta reveal">
        {lodge.destination && (
          <p class="label-eyebrow">
            <a href={`/destinations/${lodge.destination.slug}`}>{lodge.destination.name}</a>
          </p>
        )}
        {lodge.location?.lat && lodge.location?.lng && (
          <p class="label-eyebrow coords-display">{formatCoords(lodge.location.lat, lodge.location.lng)}</p>
        )}
      </div>
      <h1 class="display reveal reveal-delay-1">{lodge.name}</h1>
      {lodge.tagline && <p class="lodge-tagline reveal reveal-delay-2">{lodge.tagline}</p>}
    </div>

    <div class="container detail-body">
      <div class="detail-description">
        {editorialHtml
          ? <Fragment set:html={editorialHtml} />
          : lodge.description && <PortableText blocks={lodge.description} />
        }
      </div>
      <aside class="detail-aside">
        <div class="detail-specs">
          <p class="label-eyebrow" style="margin-bottom: 0.5rem;">At a glance</p>
          {lodge.style && (
            <div class="detail-spec-row">
              <span class="label-eyebrow">Style</span>
              <span>{lodge.style}</span>
            </div>
          )}
          {lodge.bedrooms && (
            <div class="detail-spec-row">
              <span class="label-eyebrow">Bedrooms</span>
              <span>{lodge.bedrooms}</span>
            </div>
          )}
          {lodge.sleeps && (
            <div class="detail-spec-row">
              <span class="label-eyebrow">Sleeps</span>
              <span>{lodge.sleeps}</span>
            </div>
          )}
          <div class="detail-spec-row">
            <span class="label-eyebrow">Price</span>
            <span>{priceDisplay}</span>
          </div>
          {lodge.altitude && (
            <div class="detail-spec-row">
              <span class="label-eyebrow">Altitude</span>
              <span>{lodge.altitude.toLocaleString()}m</span>
            </div>
          )}
        </div>
      </aside>
    </div>

    {(lodge.accessAndLogistics || lodge.seasonWindow || lodge.terrain || lodge.physicalRequirements?.level) && (
      <div class="container guide-boxes">
        {lodge.accessAndLogistics && (
          <div class="detail-tag-section">
            <p class="detail-tag-section-label">Access & Logistics</p>
            <p class="guide-text">{lodge.accessAndLogistics}</p>
          </div>
        )}
        {lodge.seasonWindow && (
          <div class="detail-tag-section" style="margin-top: -1px;">
            <p class="detail-tag-section-label">Season Window & What to Expect</p>
            <p class="guide-text">{lodge.seasonWindow}</p>
          </div>
        )}
        {lodge.terrain && (
          <div class="detail-tag-section" style="margin-top: -1px;">
            <p class="detail-tag-section-label">Terrain</p>
            <p class="guide-text">{lodge.terrain}</p>
          </div>
        )}
        {lodge.physicalRequirements?.level && (
          <div class="detail-tag-section" style="margin-top: -1px;">
            <p class="detail-tag-section-label">Physical Requirements</p>
            <div style="display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap;">
              <span
                class="physical-level"
                style={`color: ${levelColor[lodge.physicalRequirements.level] ?? "var(--ember)"}`}
              >{lodge.physicalRequirements.level}</span>
              {lodge.physicalRequirements.descriptor && (
                <p class="guide-text" style="margin: 0;">{lodge.physicalRequirements.descriptor}</p>
              )}
            </div>
          </div>
        )}
      </div>
    )}

    {lodge.signatureExperiences?.length > 0 && (
      <div class="container guide-section">
        <p class="label-eyebrow guide-section-label">Signature Experiences</p>
        <div class="experiences-grid">
          {lodge.signatureExperiences.map((exp: { name: string; description?: string; link?: string }) => (
            <div class="experience-card">
              <p class="label-eyebrow">Experience</p>
              <h3 class="experience-name display">{exp.name}</h3>
              {exp.description && <p class="experience-desc">{exp.description}</p>}
              {exp.link && <a href={exp.link} class="experience-link">Explore →</a>}
            </div>
          ))}
        </div>
      </div>
    )}

    {lodge.faqs?.length > 0 && (
      <div class="container faq-section">
        <p class="label-eyebrow">Frequently Asked</p>
        <ul class="faq-list">
          {lodge.faqs.map((faq: { question: string; answer: string }) => (
            <li class="faq-item">
              <p class="faq-question">{faq.question}</p>
              <p class="faq-answer">{faq.answer}</p>
            </li>
          ))}
        </ul>
      </div>
    )}

    {lodge.amenities?.length > 0 && (
      <div class="container" style="padding-block: clamp(2rem, 4vw, 3rem) 0; border-top: 1px solid var(--border);">
        <div class="detail-tag-section">
          <p class="detail-tag-section-label">Amenities</p>
          <ul class="tag-list">
            {lodge.amenities.map((a: string) => <li class="tag">{a}</li>)}
          </ul>
        </div>
      </div>
    )}

    {lodge.includedServices?.length > 0 && (
      <div class="container" style="padding-block: 0;">
        <div class="detail-tag-section" style="margin-top: -1px;">
          <p class="detail-tag-section-label">Included Services</p>
          <ul class="tag-list">
            {lodge.includedServices.map((s: string) => <li class="tag">{s}</li>)}
          </ul>
        </div>
      </div>
    )}

    {lodge.onRequest?.length > 0 && (
      <div class="container" style="padding-block: 0;">
        <div class="detail-tag-section" style="margin-top: -1px;">
          <p class="detail-tag-section-label">On Request</p>
          <ul class="tag-list">
            {lodge.onRequest.map((r: string) => <li class="tag">{r}</li>)}
          </ul>
        </div>
      </div>
    )}

    {lodge.location?.lat && lodge.location?.lng && (
      <PropertyMap lat={lodge.location.lat} lng={lodge.location.lng} label={lodge.name} />
    )}

    <LightboxGallery images={lodge.gallery ?? []} />

    <EnquiryCTA propertyName={lodge.name} />
  </main>
  <Footer />
</BaseLayout>
