---
import BaseLayout from "../../layouts/BaseLayout.astro";
import NavSummitX from "../../components/NavSummitX.astro";
import Footer from "../../components/Footer.astro";
import { sanityClient } from "../../lib/sanity";

const heliSkis = await sanityClient.fetch(`
  *[_type == "heliSki"] | order(name asc) {
    _id, name, slug, terrainType, season,
    "cardUrl": gallery[0].asset->url + "?w=800&auto=format",
    "destination": destination->name
  }
`);
---

<BaseLayout title="Heli-Ski — Summit X" description="Private heli-ski programmes in the world's most dramatic mountain terrain.">
  <NavSummitX />
  <main id="main">
    <div class="page-hero container">
      <p class="label-eyebrow reveal">Collection</p>
      <h1 class="display reveal reveal-delay-1">Heli-Ski</h1>
    </div>
    <div class="container">
      {heliSkis.length === 0 ? (
        <p style="padding-block: 4rem; color: var(--muted-foreground);">Heli-ski programmes coming soon.</p>
      ) : (
        <div class="card-grid">
          {heliSkis.map((hs: any) => (
            <a href={`/heli-ski/${hs.slug.current}`} class="card reveal">
              <div class="card-media image-frame">
                {hs.cardUrl && <img src={hs.cardUrl} alt={hs.name} loading="lazy" />}
              </div>
              <div class="card-body">
                <p class="label-eyebrow">
                  {[hs.terrainType, hs.season, hs.destination].filter(Boolean).join(" · ")}
                </p>
                <h2 class="card-title display">{hs.name}</h2>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </main>
  <Footer />
</BaseLayout>
