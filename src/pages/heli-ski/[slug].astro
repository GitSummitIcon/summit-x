---
import BaseLayout from "../../layouts/BaseLayout.astro";
import NavSummitX from "../../components/NavSummitX.astro";
import Footer from "../../components/Footer.astro";
import PortableText from "../../components/PortableText.astro";
import EnquiryCTA from "../../components/EnquiryCTA.astro";
import LightboxGallery from "../../components/LightboxGallery.astro";
import PropertyMap from "../../components/PropertyMap.astro";
import { sanityClient } from "../../lib/sanity";

export async function getStaticPaths() {
  const items = await sanityClient.fetch(`*[_type == "heliSki"]{ "slug": slug.current }`);
  return items.map((item: { slug: string }) => ({ params: { slug: item.slug } }));
}

const { slug } = Astro.params;

const heliSki = await sanityClient.fetch(`
  *[_type == "heliSki" && slug.current == $slug][0] {
    name, terrainType, season, groupSize, description, vimeoUrl,
    accessAndLogistics, seasonWindow, terrain,
    physicalRequirements { level, descriptor },
    "location": location{ lat, lng },
    "heroUrl": gallery[0].asset->url + "?w=1600&auto=format",
    "gallery": gallery[]{ "url": asset->url + "?w=1200&auto=format" },
    "destination": destination->{ name, "slug": slug.current }
  }
`, { slug });

if (!heliSki) return Astro.redirect("/heli-ski");

const levelColor: Record<string, string> = {
  None: "#7ab97a",
  Moderate: "var(--ember)",
  Demanding: "#d96060",
};

const descParts = [
  heliSki.destination?.name && `in ${heliSki.destination.name}`,
  heliSki.terrainType && `${heliSki.terrainType} terrain`,
  heliSki.season && `${heliSki.season} season`,
].filter(Boolean).join(", ");
const description = `${heliSki.name}${descParts ? ` — ${descParts}` : ""}. Exclusive heli-ski experience curated by Summit X.`;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "TouristTrip",
  name: heliSki.name,
  description,
  url: `https://summitx.iconprivatecollection.com/heli-ski/${slug}`,
  ...(heliSki.heroUrl && { image: heliSki.heroUrl }),
  ...(heliSki.destination && { itinerary: { "@type": "Place", name: heliSki.destination.name } }),
  touristType: "Ski enthusiasts",
  provider: {
    "@type": "TravelAgency",
    name: "Summit X",
    email: "summitx@iconprivatecollection.com",
    parentOrganization: { "@type": "Organization", name: "Icon Private Collection" },
  },
};
---

<BaseLayout
  title={`${heliSki.name} — Summit X`}
  description={description}
  image={heliSki.heroUrl ?? undefined}
  structuredData={structuredData}
>
  <NavSummitX />
  <main id="main">
    {heliSki.heroUrl && (
      <div class="detail-hero">
        <img src={heliSki.heroUrl} alt={heliSki.name} loading="eager" />
        <div class="overlay" style="background: var(--grad-veil);"></div>
        {heliSki.vimeoUrl && (
          <div id="hero-video-overlay" class="hero-video-overlay" hidden>
            <iframe id="hero-video" class="hero-video-player" src="" allow="autoplay; fullscreen" allowfullscreen></iframe>
          </div>
        )}
        <div class="hero-media-btns">
          {heliSki.vimeoUrl && (
            <button class="hero-watch-film" id="watch-film-btn">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              Watch film
            </button>
          )}
          {heliSki.gallery?.length > 1 && (
            <button class="hero-photo-count" data-lb-open="0">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
              {heliSki.gallery.length} photos
            </button>
          )}
        </div>
      </div>
    )}
    <script is:inline define:vars={{ vimeoUrl: heliSki.vimeoUrl }}>
      if (vimeoUrl) {
        const btn = document.getElementById("watch-film-btn");
        const video = document.getElementById("hero-video");
        const videoId = vimeoUrl.match(/(?:vimeo\.com\/)(\d+)/)?.[1];
        const overlay = document.getElementById("hero-video-overlay");
        const embedUrl = "https://player.vimeo.com/video/" + videoId + "?autoplay=1&title=0&byline=0&portrait=0";
        function openVideo() { video.src = embedUrl; overlay.hidden = false; btn.hidden = true; }
        function closeVideo() { overlay.hidden = true; video.src = ""; btn.hidden = false; }
        btn?.addEventListener("click", openVideo);
        overlay?.addEventListener("click", function(e) { if (!e.target.closest(".hero-video-player")) closeVideo(); });
        document.addEventListener("keydown", function(e) { if (e.key === "Escape" && !overlay.hidden) closeVideo(); });
      }
    </script>

    <div class="detail-header container">
      {heliSki.destination && (
        <p class="label-eyebrow reveal">
          <a href={`/destinations/${heliSki.destination.slug}`}>{heliSki.destination.name}</a>
        </p>
      )}
      <h1 class="display reveal reveal-delay-1">{heliSki.name}</h1>
    </div>

    <div class="container detail-body">
      <div class="detail-description">
        {heliSki.description && <PortableText blocks={heliSki.description} />}
      </div>
      <aside class="detail-aside">
        <div class="detail-specs">
          <p class="label-eyebrow" style="margin-bottom: 0.5rem;">At a glance</p>
          {heliSki.terrainType && (
            <div class="detail-spec-row">
              <span class="label-eyebrow">Terrain</span>
              <span>{heliSki.terrainType}</span>
            </div>
          )}
          {heliSki.season && (
            <div class="detail-spec-row">
              <span class="label-eyebrow">Season</span>
              <span>{heliSki.season}</span>
            </div>
          )}
          {heliSki.groupSize && (
            <div class="detail-spec-row">
              <span class="label-eyebrow">Group size</span>
              <span>{heliSki.groupSize}</span>
            </div>
          )}
        </div>
      </aside>
    </div>

    {(heliSki.accessAndLogistics || heliSki.seasonWindow || heliSki.terrain || heliSki.physicalRequirements?.level) && (
      <div class="container guide-boxes">
        {heliSki.accessAndLogistics && (
          <div class="detail-tag-section">
            <p class="detail-tag-section-label">Access & Logistics</p>
            <p class="guide-text">{heliSki.accessAndLogistics}</p>
          </div>
        )}
        {heliSki.seasonWindow && (
          <div class="detail-tag-section" style="margin-top: -1px;">
            <p class="detail-tag-section-label">Season Window & What to Expect</p>
            <p class="guide-text">{heliSki.seasonWindow}</p>
          </div>
        )}
        {heliSki.terrain && (
          <div class="detail-tag-section" style="margin-top: -1px;">
            <p class="detail-tag-section-label">Terrain</p>
            <p class="guide-text">{heliSki.terrain}</p>
          </div>
        )}
        {heliSki.physicalRequirements?.level && (
          <div class="detail-tag-section" style="margin-top: -1px;">
            <p class="detail-tag-section-label">Physical Requirements</p>
            <div style="display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap;">
              <span
                class="physical-level"
                style={`color: ${levelColor[heliSki.physicalRequirements.level] ?? "var(--ember)"}`}
              >{heliSki.physicalRequirements.level}</span>
              {heliSki.physicalRequirements.descriptor && (
                <p class="guide-text" style="margin: 0;">{heliSki.physicalRequirements.descriptor}</p>
              )}
            </div>
          </div>
        )}
      </div>
    )}

    {heliSki.location?.lat && heliSki.location?.lng && (
      <PropertyMap lat={heliSki.location.lat} lng={heliSki.location.lng} label={heliSki.name} />
    )}

    <LightboxGallery images={heliSki.gallery ?? []} />

    <EnquiryCTA propertyName={heliSki.name} />
  </main>
  <Footer />
</BaseLayout>
