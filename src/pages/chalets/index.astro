---
import BaseLayout from "../../layouts/BaseLayout.astro";
import NavSummitX from "../../components/NavSummitX.astro";
import Footer from "../../components/Footer.astro";
import { sanityClient } from "../../lib/sanity";

const chalets = await sanityClient.fetch(`
  *[_type == "chalet"] | order(name asc) {
    _id, name, slug, bedrooms, sleeps,
    "cardUrl": gallery[0].asset->url + "?w=800&auto=format",
    "destination": destination->name
  }
`);
---

<BaseLayout title="Chalets — Summit X" description="Handpicked alpine chalets for discerning travellers.">
  <NavSummitX />
  <main id="main">
    <div class="page-hero container">
      <p class="label-eyebrow reveal">Collection</p>
      <h1 class="display reveal reveal-delay-1">Chalets</h1>
    </div>
    <div class="container">
      {chalets.length === 0 ? (
        <p style="padding-block: 4rem; color: var(--muted-foreground);">Chalets coming soon.</p>
      ) : (
        <div class="card-grid">
          {chalets.map((chalet: any) => (
            <a href={`/chalets/${chalet.slug.current}`} class="card reveal">
              <div class="card-media image-frame">
                {chalet.cardUrl && <img src={chalet.cardUrl} alt={chalet.name} loading="lazy" />}
              </div>
              <div class="card-body">
                <p class="label-eyebrow">
                  {[chalet.bedrooms && `${chalet.bedrooms} bed`, chalet.sleeps && `sleeps ${chalet.sleeps}`, chalet.destination].filter(Boolean).join(" · ")}
                </p>
                <h2 class="card-title display">{chalet.name}</h2>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </main>
  <Footer />
</BaseLayout>
