---
import BaseLayout from "../../layouts/BaseLayout.astro";
import NavSummitX from "../../components/NavSummitX.astro";
import Footer from "../../components/Footer.astro";
import PortableText from "../../components/PortableText.astro";
import EnquiryCTA from "../../components/EnquiryCTA.astro";
import LightboxGallery from "../../components/LightboxGallery.astro";
import PropertyMap from "../../components/PropertyMap.astro";
import { sanityClient } from "../../lib/sanity";

export async function getStaticPaths() {
  const items = await sanityClient.fetch(`*[_type == "chalet"]{ "slug": slug.current }`);
  return items.map((item: { slug: string }) => ({ params: { slug: item.slug } }));
}

const { slug } = Astro.params;

const chalet = await sanityClient.fetch(`
  *[_type == "chalet" && slug.current == $slug][0] {
    name, bedrooms, sleeps, priceOnRequest, priceRange, amenities, includedServices, onRequest, description, altitude, vimeoUrl,
    "location": location{ lat, lng },
    "heroUrl": gallery[0].asset->url + "?w=1600&auto=format",
    "gallery": gallery[]{ "url": asset->url + "?w=1200&auto=format" },
    "destination": destination->{ name, "slug": slug.current }
  }
`, { slug });

if (!chalet) return Astro.redirect("/chalets");

const priceDisplay = chalet.priceOnRequest || !chalet.priceRange?.min
  ? "Price on request"
  : `${chalet.priceRange.currency ?? "GBP"} ${chalet.priceRange.min.toLocaleString()}–${chalet.priceRange.max?.toLocaleString() ?? ""}`;

const descParts = [
  chalet.destination?.name && `in ${chalet.destination.name}`,
  chalet.bedrooms && `${chalet.bedrooms} bedrooms`,
  chalet.sleeps && `sleeps ${chalet.sleeps}`,
].filter(Boolean).join(", ");
const description = `${chalet.name}${descParts ? ` — ${descParts}` : ""}. A luxury alpine chalet curated by Summit X.`;

function formatCoords(lat: number, lng: number): string {
  const fmt = (n: number) => (Math.trunc(n * 100) / 100).toFixed(2);
  const latDir = lat >= 0 ? "N" : "S";
  const lngDir = lng >= 0 ? "E" : "W";
  return `${fmt(lat)}°${latDir} · ${fmt(lng)}°${lngDir}`;
}

const structuredData = {
  "@context": "https://schema.org",
  "@type": "LodgingBusiness",
  name: chalet.name,
  description,
  url: `https://summitx.iconprivatecollection.com/chalets/${slug}`,
  ...(chalet.heroUrl && { image: chalet.heroUrl }),
  ...(chalet.destination && { location: { "@type": "Place", name: chalet.destination.name } }),
  numberOfRooms: chalet.bedrooms,
  ...(chalet.amenities?.length && {
    amenityFeature: chalet.amenities.map((a: string) => ({ "@type": "LocationFeatureSpecification", name: a, value: true })),
  }),
  brand: { "@type": "Brand", name: "Summit X" },
  parentOrganization: { "@type": "Organization", name: "Icon Private Collection" },
  email: "summitx@iconprivatecollection.com",
};
---

<BaseLayout
  title={`${chalet.name} — Summit X`}
  description={description}
  image={chalet.heroUrl ?? undefined}
  structuredData={structuredData}
>
  <NavSummitX />
  <main id="main">
    {chalet.heroUrl && (
      <div class="detail-hero">
        <img src={chalet.heroUrl} alt={chalet.name} loading="eager" />
        <div class="overlay" style="background: var(--grad-veil);"></div>
        <div class="hero-media-btns">
          {chalet.vimeoUrl && (
            <button class="hero-watch-film" id="watch-film-btn">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              Watch film
            </button>
          )}
          {chalet.gallery?.length > 1 && (
            <button class="hero-photo-count" data-lb-open="0">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
              {chalet.gallery.length} photos
            </button>
          )}
        </div>
      </div>
    )}
    {chalet.vimeoUrl && (
      <div class="video-modal" id="video-modal" hidden>
        <div class="video-modal-backdrop" id="video-modal-backdrop"></div>
        <button class="video-modal-close" id="video-modal-close" aria-label="Close video">&#215;</button>
        <div class="video-modal-frame">
          <iframe id="video-modal-iframe" src="" allow="autoplay; fullscreen" allowfullscreen></iframe>
        </div>
      </div>
    )}
    <script is:inline define:vars={{ vimeoUrl: chalet.vimeoUrl }}>
      if (vimeoUrl) {
        const btn = document.getElementById("watch-film-btn");
        const modal = document.getElementById("video-modal");
        const iframe = document.getElementById("video-modal-iframe");
        const backdrop = document.getElementById("video-modal-backdrop");
        const closeBtn = document.getElementById("video-modal-close");
        const videoId = vimeoUrl.match(/vimeo\.com\/(\d+)/)?.[1];
        const embedUrl = "https://player.vimeo.com/video/" + videoId + "?autoplay=1&title=0&byline=0&portrait=0";
        function openModal() { iframe.src = embedUrl; modal.hidden = false; document.body.style.overflow = "hidden"; }
        function closeModal() { modal.hidden = true; iframe.src = ""; document.body.style.overflow = ""; }
        btn?.addEventListener("click", openModal);
        modal?.addEventListener("click", function(e) { if (!e.target.closest(".video-modal-frame")) closeModal(); });
        closeBtn?.addEventListener("click", closeModal);
        document.addEventListener("keydown", function(e) { if (e.key === "Escape") closeModal(); });
      }
    </script>

    <div class="detail-header container">
      <div class="detail-header-meta reveal">
        {chalet.destination && (
          <p class="label-eyebrow">
            <a href={`/destinations/${chalet.destination.slug}`}>{chalet.destination.name}</a>
          </p>
        )}
        {chalet.location?.lat && chalet.location?.lng && (
          <p class="label-eyebrow coords-display">{formatCoords(chalet.location.lat, chalet.location.lng)}</p>
        )}
      </div>
      <h1 class="display reveal reveal-delay-1">{chalet.name}</h1>
    </div>

    <div class="container detail-body">
      <div class="detail-description">
        {chalet.description && <PortableText blocks={chalet.description} />}
      </div>
      <aside class="detail-aside">
        <div class="detail-specs">
          <p class="label-eyebrow" style="margin-bottom: 0.5rem;">At a glance</p>
          {chalet.bedrooms && (
            <div class="detail-spec-row">
              <span class="label-eyebrow">Bedrooms</span>
              <span>{chalet.bedrooms}</span>
            </div>
          )}
          {chalet.sleeps && (
            <div class="detail-spec-row">
              <span class="label-eyebrow">Sleeps</span>
              <span>{chalet.sleeps}</span>
            </div>
          )}
          <div class="detail-spec-row">
            <span class="label-eyebrow">Price</span>
            <span>{priceDisplay}</span>
          </div>
          {chalet.altitude && (
            <div class="detail-spec-row">
              <span class="label-eyebrow">Altitude</span>
              <span>{chalet.altitude.toLocaleString()}m</span>
            </div>
          )}
        </div>
      </aside>
    </div>

    {chalet.amenities?.length > 0 && (
      <div class="container">
        <div class="detail-aside" style="grid-column: 9 / span 4;">
          <div class="detail-tag-section">
            <p class="detail-tag-section-label">Amenities</p>
            <ul class="tag-list">
              {chalet.amenities.map((a: string) => <li class="tag">{a}</li>)}
            </ul>
          </div>
        </div>
      </div>
    )}

    {chalet.includedServices?.length > 0 && (
      <div class="container">
        <div class="detail-aside" style="grid-column: 9 / span 4;">
          <div class="detail-tag-section">
            <p class="detail-tag-section-label">Included Services</p>
            <ul class="tag-list">
              {chalet.includedServices.map((s: string) => <li class="tag">{s}</li>)}
            </ul>
          </div>
        </div>
      </div>
    )}

    {chalet.onRequest?.length > 0 && (
      <div class="container">
        <div class="detail-aside" style="grid-column: 9 / span 4;">
          <div class="detail-tag-section">
            <p class="detail-tag-section-label">On Request</p>
            <ul class="tag-list">
              {chalet.onRequest.map((r: string) => <li class="tag">{r}</li>)}
            </ul>
          </div>
        </div>
      </div>
    )}

    {chalet.location?.lat && chalet.location?.lng && (
      <PropertyMap lat={chalet.location.lat} lng={chalet.location.lng} label={chalet.name} />
    )}

    <LightboxGallery images={chalet.gallery ?? []} />

    <EnquiryCTA propertyName={chalet.name} />
  </main>
  <Footer />
</BaseLayout>
