---
import BaseLayout from "../../layouts/BaseLayout.astro";
import NavSummitX from "../../components/NavSummitX.astro";
import Footer from "../../components/Footer.astro";
import PortableText from "../../components/PortableText.astro";
import EnquiryCTA from "../../components/EnquiryCTA.astro";
import LightboxGallery from "../../components/LightboxGallery.astro";
import PropertyMap from "../../components/PropertyMap.astro";
import { sanityClient } from "../../lib/sanity";

export async function getStaticPaths() {
  const items = await sanityClient.fetch(`*[_type == "expedition"]{ "slug": slug.current }`);
  return items.map((item: { slug: string }) => ({ params: { slug: item.slug } }));
}

const { slug } = Astro.params;

const expedition = await sanityClient.fetch(`
  *[_type == "expedition" && slug.current == $slug][0] {
    name, lodgeType, season, duration, description, vimeoUrl,
    tagline, editorialIntro, seoTitle, metaDescription,
    accessAndLogistics, seasonWindow, terrain,
    physicalRequirements { level, descriptor },
    faqs[] { question, answer },
    "location": location{ lat, lng },
    "heroUrl": gallery[0].asset->url + "?w=1600&auto=format",
    "gallery": gallery[]{ "url": asset->url + "?w=1200&auto=format" },
    "destination": destination->{ name, "slug": slug.current }
  }
`, { slug });

if (!expedition) return Astro.redirect("/expeditions");

const seoTitle = expedition.seoTitle ?? `${expedition.name} — Summit X`;

const descParts = [
  expedition.destination?.name && `in ${expedition.destination.name}`,
  expedition.duration,
  expedition.season && `${expedition.season} season`,
].filter(Boolean).join(", ");
const seoDescription = expedition.metaDescription
  ?? `${expedition.name}${descParts ? ` — ${descParts}` : ""}. A guided mountain expedition curated by Summit X.`;

const levelColor: Record<string, string> = {
  None: "#7ab97a",
  Moderate: "var(--ember)",
  Demanding: "#d96060",
};

function textToHtml(text: string): string {
  const escaped = text.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
  return escaped
    .split(/\n\n+/)
    .map(para => `<p>${para.trim().replace(/\n/g, "<br>")}</p>`)
    .join("");
}
const editorialHtml = expedition.editorialIntro ? textToHtml(expedition.editorialIntro) : null;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "TouristTrip",
  name: expedition.name,
  description: seoDescription,
  url: `https://summitx.iconprivatecollection.com/expeditions/${slug}`,
  ...(expedition.heroUrl && { image: expedition.heroUrl }),
  ...(expedition.destination && { itinerary: { "@type": "Place", name: expedition.destination.name } }),
  ...(expedition.duration && { duration: expedition.duration }),
  touristType: "Adventure travellers",
  provider: {
    "@type": "TravelAgency",
    name: "Summit X",
    email: "summitx@iconprivatecollection.com",
    parentOrganization: { "@type": "Organization", name: "Icon Private Collection" },
  },
};
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  image={expedition.heroUrl ?? undefined}
  structuredData={structuredData}
>
  <NavSummitX />
  <main id="main">

    {expedition.heroUrl && (
      <div class="detail-hero">
        <img src={expedition.heroUrl} alt={expedition.name} loading="eager" />
        <div class="overlay" style="background: var(--grad-veil);"></div>
        {expedition.vimeoUrl && (
          <div id="hero-video-overlay" class="hero-video-overlay" hidden>
            <iframe id="hero-video" class="hero-video-player" src="" allow="autoplay; fullscreen" allowfullscreen></iframe>
          </div>
        )}
        <div class="hero-media-btns">
          {expedition.vimeoUrl && (
            <button class="hero-watch-film" id="watch-film-btn">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              Watch film
            </button>
          )}
          {expedition.gallery?.length > 1 && (
            <button class="hero-photo-count" data-lb-open="0">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
              {expedition.gallery.length} photos
            </button>
          )}
        </div>
      </div>
    )}
    <script is:inline define:vars={{ vimeoUrl: expedition.vimeoUrl }}>
      if (vimeoUrl) {
        const btn = document.getElementById("watch-film-btn");
        const video = document.getElementById("hero-video");
        const videoId = vimeoUrl.match(/(?:vimeo\.com\/)(\d+)/)?.[1];
        const overlay = document.getElementById("hero-video-overlay");
        const embedUrl = "https://player.vimeo.com/video/" + videoId + "?autoplay=1&title=0&byline=0&portrait=0";
        function openVideo() { video.src = embedUrl; overlay.hidden = false; btn.hidden = true; document.body.style.overflow = "hidden"; }
        function closeVideo() { overlay.hidden = true; video.src = ""; btn.hidden = false; document.body.style.overflow = ""; }
        btn?.addEventListener("click", openVideo);
        overlay?.addEventListener("click", function(e) { if (!e.target.closest(".hero-video-player")) closeVideo(); });
        document.addEventListener("keydown", function(e) { if (e.key === "Escape" && !overlay.hidden) closeVideo(); });
      }
    </script>

    <div class="detail-header container">
      {expedition.destination && (
        <p class="label-eyebrow reveal">
          <a href={`/destinations/${expedition.destination.slug}`}>{expedition.destination.name}</a>
        </p>
      )}
      <h1 class="display reveal reveal-delay-1">{expedition.name}</h1>
      {expedition.tagline && <p class="lodge-tagline reveal reveal-delay-2">{expedition.tagline}</p>}
    </div>

    <div class="container detail-body">
      <div class="detail-description">
        {editorialHtml
          ? <Fragment set:html={editorialHtml} />
          : expedition.description && <PortableText blocks={expedition.description} />
        }
      </div>
      <aside class="detail-aside">
        <div class="detail-specs">
          <p class="label-eyebrow" style="margin-bottom: 0.5rem;">At a glance</p>
          {expedition.lodgeType && (
            <div class="detail-spec-row">
              <span class="label-eyebrow">Lodge type</span>
              <span>{expedition.lodgeType}</span>
            </div>
          )}
          {expedition.season && (
            <div class="detail-spec-row">
              <span class="label-eyebrow">Season</span>
              <span>{expedition.season}</span>
            </div>
          )}
          {expedition.duration && (
            <div class="detail-spec-row">
              <span class="label-eyebrow">Duration</span>
              <span>{expedition.duration}</span>
            </div>
          )}
        </div>
      </aside>
    </div>

    {(expedition.accessAndLogistics || expedition.seasonWindow || expedition.terrain || expedition.physicalRequirements?.level) && (
      <div class="container guide-boxes">
        {expedition.accessAndLogistics && (
          <div class="detail-tag-section">
            <p class="detail-tag-section-label">Access & Logistics</p>
            <p class="guide-text">{expedition.accessAndLogistics}</p>
          </div>
        )}
        {expedition.seasonWindow && (
          <div class="detail-tag-section" style="margin-top: -1px;">
            <p class="detail-tag-section-label">Season Window & What to Expect</p>
            <p class="guide-text">{expedition.seasonWindow}</p>
          </div>
        )}
        {expedition.terrain && (
          <div class="detail-tag-section" style="margin-top: -1px;">
            <p class="detail-tag-section-label">Terrain</p>
            <p class="guide-text">{expedition.terrain}</p>
          </div>
        )}
        {expedition.physicalRequirements?.level && (
          <div class="detail-tag-section" style="margin-top: -1px;">
            <p class="detail-tag-section-label">Physical Requirements</p>
            <div style="display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap;">
              <span
                class="physical-level"
                style={`color: ${levelColor[expedition.physicalRequirements.level] ?? "var(--ember)"}`}
              >{expedition.physicalRequirements.level}</span>
              {expedition.physicalRequirements.descriptor && (
                <p class="guide-text" style="margin: 0;">{expedition.physicalRequirements.descriptor}</p>
              )}
            </div>
          </div>
        )}
      </div>
    )}

    {expedition.faqs?.length > 0 && (
      <div class="container faq-section">
        <p class="label-eyebrow">Frequently Asked</p>
        <ul class="faq-list">
          {expedition.faqs.map((faq: { question: string; answer: string }) => (
            <li class="faq-item">
              <p class="faq-question">{faq.question}</p>
              <p class="faq-answer">{faq.answer}</p>
            </li>
          ))}
        </ul>
      </div>
    )}

    {expedition.location?.lat && expedition.location?.lng && (
      <PropertyMap lat={expedition.location.lat} lng={expedition.location.lng} label={expedition.name} />
    )}

    <LightboxGallery images={expedition.gallery ?? []} />

    <EnquiryCTA propertyName={expedition.name} />
  </main>
  <Footer />
</BaseLayout>
