---
const { propertyName } = Astro.props as { propertyName: string };
const from = encodeURIComponent(Astro.url.pathname);
const property = encodeURIComponent(propertyName);
---

<section class="enquiry-section surface-section">
  <div class="container enquiry-inner">
    <div>
      <p class="label-eyebrow">Enquire</p>
      <h2 class="display">
        Interested in<br />
        <span class="display-italic" style="color: var(--ember);">{propertyName}?</span>
      </h2>
      <p style="color: var(--muted-foreground); max-width: 28rem; line-height: 1.7; margin-top: 1rem;">
        Our team will be in touch within 24 hours to discuss availability, pricing, and everything you need to plan your stay.
      </p>
    </div>
    <a class="button-link" href={`/?from=${from}&property=${property}#enquire`}>
      Make an enquiry <span aria-hidden="true">&rarr;</span>
    </a>
  </div>
</section>
