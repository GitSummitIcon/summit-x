---
type Span = { _key: string; text: string; marks?: string[] };
type Block = { _key: string; _type: string; style?: string; children?: Span[] };

const { blocks } = Astro.props as { blocks: Block[] | null | undefined };
---

{blocks?.map((block) => {
  if (block._type !== "block") return null;
  const text = block.children?.map((s) => s.text).join("") ?? "";
  if (block.style === "h2") return <h2>{text}</h2>;
  if (block.style === "h3") return <h3>{text}</h3>;
  if (block.style === "blockquote") return <blockquote>{text}</blockquote>;
  return <p>{text}</p>;
})}
